<?xml version="1.0" encoding="UTF-8"?>

<!-- ============================================================
     设置页面 — settings.fxml
     提供应用级偏好设置：
       - 关闭时最小化到系统托盘（CheckBox）
     由 SettingsController 控制
     ============================================================ -->

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21.0.11"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.screentime.controller.SettingsController"
      spacing="16.0">
    <padding>
        <Insets top="12.0" right="16.0" bottom="12.0" left="16.0"/>
    </padding>

    <Label text="设置"
           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <Separator/>

    <!-- 常规设置 -->
    <VBox spacing="12.0" style="-fx-background-color: white; -fx-padding: 16; -fx-background-radius: 6;">
        <Label text="常规" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

        <CheckBox fx:id="cbMinimizeToTray" text="关闭时最小化到系统托盘"
                  style="-fx-font-size: 13px; -fx-text-fill: #2c3e50;"/>

        <HBox spacing="12.0" alignment="CENTER_LEFT">
            <CheckBox fx:id="cbStartup" text="开机自启"
                      style="-fx-font-size: 13px; -fx-text-fill: #2c3e50;"/>
            <CheckBox fx:id="cbStartMinimized" text="开机静默启动（最小化到托盘）"
                      style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
        </HBox>

        <Separator/>

        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <Label text="短时运行过滤（秒）：" style="-fx-font-size: 13px; -fx-text-fill: #2c3e50;"/>
            <Spinner fx:id="spMinSession" prefWidth="80"
                     editable="true" style="-fx-font-size: 13px;"/>
            <Label text="（应用停留小于此秒数不记录，默认 30）"
                   style="-fx-font-size: 11px; -fx-text-fill: #95a5a6;"/>
        </HBox>
    </VBox>


    <!-- 数据导出 -->
    <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 16; -fx-background-radius: 6;">
        <Label text="数据" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <Button fx:id="btnExport" text="导出数据（CSV）"
                    style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-size: 13px;"/>
            <Button fx:id="btnImport" text="导入数据（CSV）"
                    style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-size: 13px;"/>
            <Label text="导出/导入 CSV 文件（导入追加到本地数据之上）"
                   style="-fx-font-size: 11px; -fx-text-fill: #95a5a6;"/>
        </HBox>
    </VBox>

    <Label fx:id="lblSaveHint" style="-fx-font-size: 12px; -fx-text-fill: #27ae60;" visible="false"/>
</VBox>
