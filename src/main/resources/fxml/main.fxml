<?xml version="1.0" encoding="UTF-8"?>

<!-- ============================================================
     主界面布局 — main.fxml
     BorderPane 结构：
       left:   左侧导航栏（VBox，三个导航按钮）
       center: 内容区（StackPane，动态切换页面）
     由 MainController 控制导航路由
     ============================================================ -->

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="root" minHeight="600.0" minWidth="900.0"
            xmlns="http://javafx.com/javafx/21.0.11"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.screentime.controller.MainController">

    <!-- 左侧导航栏 -->
    <left>
        <VBox fx:id="navBar" spacing="8.0" style="-fx-background-color: #2c3e50; -fx-padding: 20 10 20 10;"
              prefWidth="160.0" fillWidth="true">
            <Button fx:id="btnMonitorList" text="监控软件管理" maxWidth="Infinity" prefHeight="36.0"
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14px;"/>
            <Button fx:id="btnStatistics" text="使用统计" maxWidth="Infinity" prefHeight="36.0"
                    style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-size: 14px;"/>
            <Button fx:id="btnSettings" text="设置" maxWidth="Infinity" prefHeight="36.0"
                    style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-size: 14px;"/>
        </VBox>
    </left>

    <!-- 右侧内容区 -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-background-color: #ecf0f1;">
            <padding>
                <Insets top="16.0" right="16.0" bottom="16.0" left="16.0"/>
            </padding>
        </StackPane>
    </center>

</BorderPane>
