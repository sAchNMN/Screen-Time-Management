root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{bat,cmd}]
end_of_line = crlf

[*.{yml,yaml,json,xml,fxml,css,md,sql,properties}]
indent_size = 2

[pom.xml]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

